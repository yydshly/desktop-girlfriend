# Desktop Girlfriend example configuration
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.

# =============================================================================
# APP
# =============================================================================
APP_NAME=Desktop Girlfriend
APP_ENV=dev
LOG_LEVEL=INFO
WINDOW_WIDTH=520
WINDOW_HEIGHT=720
# Start the transparent Live2D desktop character together with the main app
LIVE2D_DESKTOP_AUTO_LAUNCH=true

# =============================================================================
# LLM / CHAT PROVIDER
# =============================================================================
# Provider mode: "fake" or "minimax"
CHAT_PROVIDER_MODE=fake

# Only fill in real values in local .env — do NOT commit real keys
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_CHAT_PATH=/text/chatcompletion_v2
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_TIMEOUT_SECONDS=30.0

# =============================================================================
# TTS PROVIDER
# =============================================================================
# Enable TTS feature
TTS_ENABLED=false
# Provider mode: "fake" or "minimax"
TTS_PROVIDER_MODE=fake

# MiniMax TTS config — falls back to chat config values if not set
MINIMAX_TTS_API_KEY=
MINIMAX_TTS_GROUP_ID=
MINIMAX_TTS_BASE_URL=https://api.minimax.chat/v1
MINIMAX_TTS_MODEL=speech-02-hd
MINIMAX_TTS_VOICE_ID=female-shaonv
MINIMAX_TTS_TIMEOUT_SECONDS=30.0
MINIMAX_TTS_PATH=/t2a_v2
MINIMAX_TTS_OUTPUT_DIR=.tmp/tts

# =============================================================================
# ASR PROVIDER
# =============================================================================
# Enable ASR feature
ASR_ENABLED=false
# Provider mode: "fake" or "mimo"
ASR_PROVIDER_MODE=fake

# Fake ASR config (used when ASR_PROVIDER_MODE=fake)
FAKE_ASR_TRANSCRIPT=这是一次语音输入测试。
FAKE_ASR_DELAY_SECONDS=0.1

# MiMo ASR config (used when ASR_PROVIDER_MODE=mimo)
# Only fill in real values in local .env — do NOT commit real keys
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_ASR_MODEL=mimo-v2.5-asr
MIMO_ASR_LANGUAGE=auto
MIMO_ASR_TIMEOUT_SECONDS=30.0

# ASR recording config
ASR_RECORDING_OUTPUT_DIR=.tmp/asr
ASR_RECORDING_SAMPLE_RATE=16000
ASR_RECORDING_CHANNELS=1
ASR_RECORDING_MAX_SECONDS=10.0
ASR_RECORDING_DEFAULT_SECONDS=4.0

# =============================================================================
# PERSONA
# =============================================================================
PERSONA_NAME=小云
PERSONA_USER_ADDRESS=你

# =============================================================================
# MEMORY  (all memory features default to OFF)
# =============================================================================
# Memory context: inject confirmed memories into LLM session context
MEMORY_CONTEXT_ENABLED=false
# Memory suggestions: detect memory-worthy content in user input
MEMORY_SUGGESTIONS_ENABLED=false
# Memory management UI: show panel to view/delete confirmed memories
MEMORY_MANAGEMENT_ENABLED=false
# Where confirmed memories are stored (JSON file)
MEMORY_STORE_PATH=.tmp/memory.json

# =============================================================================
# PROACTIVE COMPANIONSHIP  (all proactive features default to OFF)
# =============================================================================
# Enable proactive nudges when user is idle
PROACTIVE_ENABLED=false
PROACTIVE_IDLE_SECONDS=300
PROACTIVE_COOLDOWN_SECONDS=1800
PROACTIVE_MAX_PER_SESSION=3
# Route proactive nudge through TTS pipeline (speaks instead of just text)
PROACTIVE_TTS_ENABLED=false

# Proactive guardrails
PROACTIVE_QUIET_HOURS_ENABLED=false
PROACTIVE_QUIET_START_HOUR=23
PROACTIVE_QUIET_END_HOUR=8
# Pause proactive nudges after user says "别打扰" or similar
PROACTIVE_FEEDBACK_PAUSE_SECONDS=3600
